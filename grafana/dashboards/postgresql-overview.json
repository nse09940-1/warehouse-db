      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "pg_stat_database_numbackends{datname!~\"template[01]\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "title": "Connections by Database",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "rate(pg_stat_database_xact_commit{datname!~\"template[01]\"}[$__rate_interval]) + rate(pg_stat_database_xact_rollback{datname!~\"template[01]\"}[$__rate_interval])",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "title": "Transactions / sec",
      "type": "timeseries"
